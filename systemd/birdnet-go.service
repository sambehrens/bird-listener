[Unit]
Description=BirdNET-Go real-time bird detection
After=network.target sound.target
Wants=network.target

[Service]
Type=simple
User=sam
WorkingDirectory=/home/sam/bird-listener
ExecStart=/home/sam/bird-listener/bin/birdnet-go realtime --config /home/sam/.config/birdnet-go/config.yaml
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

# Give the audio subsystem time to settle after boot
ExecStartPre=/bin/sleep 5

[Install]
WantedBy=multi-user.target
